{
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "uni-app"
			}
		},
		{
			"path": "pages/login/login",
			"style": {
				"navigationBarTitleText": "登录",
				"navigationStyle": "custom",
				"enablePullDownRefresh": false,
				"app-plus": {
					"bounce": "none"
				}
			}
		}
	],
	"subPackages": [ // 模块分包
		{
			"root": "pages/student",
			"name": "student",
			"pages": [
				{
					"path": "test/test",
					"style": {
						"navigationBarTitleText": "学员",
						"navigationBarBackgroundColor": "#3875EA",
						"navigationBarTextStyle": "white",
						"app-plus": {
							// #ifdef APP-PLUS
							"titleNView": {
								"type": "default"
							}
							// #endif
						}
					}
				},
				{
					"path": "index/index",
					"style": {
						"navigationBarTitleText": "学员主页",
						"navigationBarBackgroundColor": "#3875EA",
						"navigationBarTextStyle": "white",
						"app-plus": {
							// #ifdef APP-PLUS
							"titleNView": {
								"type": "default"
							}
							// #endif
						}
					}
				},
				{
					"path": "appoint/appoint",
					"style": {
						"navigationBarTitleText": "预约",
						"navigationBarBackgroundColor": "#3875EA",
						"navigationBarTextStyle": "white",
						"app-plus": {
							// #ifdef APP-PLUS
							"titleNView": {
								"type": "default"
							}
							// #endif
						}
					}
				},
				{
					"path": "my/my",
					"style": {
						"navigationBarTitleText": "我的",
						"navigationBarBackgroundColor": "#3875EA",
						"navigationBarTextStyle": "white",
						"app-plus": {
							// #ifdef APP-PLUS
							"titleNView": {
								"type": "default"
							}
							// #endif
						}
					}
				},
			]
		},
		{
			"root": "pages/coach",
			"name": "coach",
			"pages": [
				{
					"path": "test/test",
					"style": {
						"navigationBarTitleText": "教练",
						"navigationBarBackgroundColor": "#3875EA",
						"navigationBarTextStyle": "white",
						"app-plus": {
							// #ifdef APP-PLUS
							"titleNView": {
								"type": "default"
							}
							// #endif
						}
					}
				}
			]
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"tabBar": {
		"custom": true,
		"color": "#7A7E83",
		"selectedColor": "#007AFF",
		"borderStyle": "black",
		"backgroundColor": "#FFFFFF",
		"list": [
			{
				"pagePath": "pages/index/index",
				"text": "首页"
			},
			{
				"pagePath": "pages/login/login",
				"text": "登录"
			}
		]
	},
	"condition": {
		"current": 0,
		"list": [
			{
				"name": "学员端",
				"path": "pages/student/index/index",
				"query": ""
			},
			{
				"name": "教练端",
				"path": "pages/coach/index/index",
				"query": ""
			}
		]
	},
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	}
}